# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_ledger
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_MIN_SIZE=5
POSTGRES_POOL_MAX_SIZE=20

# MCP Server Configuration
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_DEBUG=false
MCP_WORKERS=4

# Projection Daemon Configuration
PROJECTION_POLL_INTERVAL_MS=100
PROJECTION_BATCH_SIZE=500
PROJECTION_MAX_RETRIES=3
PROJECTION_RETRY_DELAY_MS=1000

# Security
ENCRYPTION_KEY=please-change-this-in-production
JWT_SECRET=please-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment
ENVIRONMENT=development
DEBUG=true